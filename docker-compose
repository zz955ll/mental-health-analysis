version: '3.8'

services:
  # Redis 缓存服务
  redis:
    image: redis:7-alpine
    container_name: mental_health_redis
    ports:
      - "6379:6379"
    restart: unless-stopped
    networks:
      - mental_network

  # Django 后端服务
  backend:
    build: .
    container_name: mental_health_backend
    ports:
      - "8000:8000"
    depends_on:
      - redis
    environment:
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - DEBUG=1
      - PYTHONUTF8=1
    volumes:
      - ./backend:/app/backend
      - ./static:/app/static
    restart: unless-stopped
    networks:
      - mental_network

networks:
  mental_network:
    driver: bridge